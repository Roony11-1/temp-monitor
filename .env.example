# ============================================
# Base de Datos
# ============================================
POSTGRES_DB=tempdb
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# ============================================
# Quarkus Datasource
# ============================================
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://temp-db:5432/tempdb
QUARKUS_DATASOURCE_USERNAME=admin
QUARKUS_DATASOURCE_PASSWORD=admin
QUARKUS_HIBERNATE_ORM_DATABASE_GENERATION=update

# ============================================
# JWT
# ============================================
JWT_EXPIRATION_HOURS=24

# Clave HMAC en Base64 (al menos 32 bytes para HS256)
SMALLRYE_JWT_SIGN_KEY=ezkyO/2l7ExQ5LfJYgGT1dVtF1WGAFMAY6vtvomGmxY=
SMALLRYE_JWT_SIGN_KEY_FORMAT=BASE64
SMALLRYE_JWT_NEW_TOKEN_SIGNATURE_ALGORITHM=HS256

# Alternativa: usar un archivo de clave privada (comentar las tres líneas de arriba)
#SMALLRYE_JWT_SIGN_KEY_LOCATION=privateKey.pem

# ============================================
# Puerto de la aplicación
# ============================================
QUARKUS_HTTP_PORT=8080