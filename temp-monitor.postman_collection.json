  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (SUPER_ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);",
                  "pm.collectionVariables.set('userEmail', json.email);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": "superadmin@example.com",\n  \"password\": "admin123"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login (ADMIN_EMPRESA)",
          "request": {
